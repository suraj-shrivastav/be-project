# ── Required: Postgres + Supabase Auth ────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...

# ── LLM Provider (at least one required) ──────────────────────
# NIM is preferred (Llama 3.3 70B + Qwen 397B); OpenRouter is the fallback.
NVIDIA_NIM_API_KEY=
OPENROUTER_API=

# ── Optional integrations ─────────────────────────────────────
TAVILY_API_KEY=        # agent's web search tool
INDIAN_API_KEY=        # live Indian markets data (BSE / NSE)

# ── CORS / frontend allowlist ─────────────────────────────────
FRONTEND_URL=http://localhost:3000
